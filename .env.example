# PALIMPS — server / build environment variables (post-Manus migration)
# Bunu kopyala: cp .env.example .env  ve gerçek değerleri doldur.
# .env dosyasını ASLA git'e commit'leme.

# ============================================================================
# Core
# ============================================================================
NODE_ENV=production
PORT=3000

# Public URL of this API server (Railway, Fly, Render, etc.)
PUBLIC_BASE_URL=https://api.palimps.app

# Application identifier (only used as the `appId` claim inside session JWTs)
APP_ID=palimps

# JWT secret used to sign + verify session cookies / Bearer tokens.
# En az 32 karakter, rastgele üret: `openssl rand -base64 48`
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Optional: openId of the project owner. The user with this id is auto-tagged
# as role="admin" on first sign-in. Format: "apple:<sub>".
OWNER_OPEN_ID=

# ============================================================================
# Database (MySQL — Railway / PlanetScale / etc.)
# ============================================================================
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql://palimps:CHANGE_ME@127.0.0.1:3306/palimps

# ============================================================================
# Authentication — Apple Sign In (only auth method)
# ============================================================================
# Must match the iOS bundle id of the app exactly.
APPLE_BUNDLE_ID=space.manus.okuma.hafizasi.mvp.t20260130232125
APPLE_TEAM_ID=S456GRHXU8

# ============================================================================
# AI — Google Gemini (direct, OpenAI-compatible endpoint)
# ============================================================================
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# File storage — Cloudflare R2 (S3-compatible)
# ============================================================================
# Create an R2 bucket + an R2 API token at
# https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=palimps
# Public URL prefix where uploaded objects are served from.
# Either a custom domain (https://files.palimps.app) or the pub-xxx.r2.dev URL.
R2_PUBLIC_BASE_URL=

# ============================================================================
# Subscriptions — RevenueCat + Apple IAP
# ============================================================================
# RevenueCat dashboard → Project settings → Webhooks
# Set the webhook URL to: ${PUBLIC_BASE_URL}/api/webhooks/revenuecat
# and copy the "Authorization" header value here.
REVENUECAT_WEBHOOK_SECRET=

# Public RevenueCat SDK key (the iOS key starts with "appl_").
# Used by the client only — exposed via EXPO_PUBLIC_REVENUECAT_IOS_API_KEY.
REVENUECAT_PUBLIC_SDK_KEY=

# ============================================================================
# Expo client (must be prefixed EXPO_PUBLIC_*)
# ============================================================================
EXPO_PUBLIC_API_BASE_URL=https://api.palimps.app
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
